generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  ATTENDANT
  SUPERVISOR
  ADMIN
}

enum TicketStatus {
  ABERTO
  EM_ATENDIMENTO
  AGUARDANDO_CLIENTE
  AGUARDANDO_ESTOQUE
  FECHADO
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  AUDIO
  IMAGE
}

enum ProductUnit {
  SACO
  M3
  UNIDADE
  LATA
}

enum ReceivableStatus {
  PENDENTE
  COBRANDO
  PAGO
  VENCIDO
  CANCELADO
}

enum ProviderType {
  META_CLOUD_API
  TWILIO_WHATSAPP
  ZENVIA_WHATSAPP
  DIALOG_360
  CUSTOM_WEBHOOK
}

enum AiMode {
  MANUAL
  ASSISTIDO
  AUTO
}

enum MessageLogStatus {
  QUEUED
  SENT
  FAILED
}

enum CustomerTier {
  PREMIUM
  RECORRENTE
  OBRA_GRANDE
  SENSIVEL_PRECO
  NOVO_CLIENTE
}

enum RiskLevel {
  BAIXO
  MEDIO
  ALTO
}

enum FollowupTaskStatus {
  PENDING
  DONE
}

enum ProductImportJobType {
  PRODUCT_IMPORT
  STOCK_UPDATE
}

enum ProductImportJobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum InventoryMovementType {
  IMPORT_SET
  IMPORT_ADD
  MANUAL_ADJUST
}

model Store {
  id            String                @id @default(cuid())
  name          String
  code          String                @unique
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  userStores    UserStore[]
  contacts      Contact[]
  conversations Conversation[]
  tickets       Ticket[]
  opportunities Opportunity[]
  products      Product[]
  priceRules    PriceRule[]
  goals         SellerGoal[]
}

model User {
  id              String         @id @default(cuid())
  name            String
  email           String         @unique
  passwordHash    String
  role            RoleName
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  userStores      UserStore[]
  assignedTickets Ticket[]       @relation("TicketAssignee")
  auditLogs       AuditLog[]
  aiApproved      AiSuggestion[] @relation("AiApprovedBy")
  importJobs      ProductImportJob[]
}

model UserStore {
  userId  String
  storeId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@id([userId, storeId])
}

model Contact {
  id            String         @id @default(cuid())
  storeId       String
  name          String
  phone         String
  cpfCnpj       String?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  store         Store          @relation(fields: [storeId], references: [id])
  addresses     Address[]
  worksites     Worksite[]
  conversations Conversation[]
  customerScore CustomerScore?

  @@index([storeId, phone])
}

model Address {
  id          String  @id @default(cuid())
  contactId   String
  label       String
  street      String
  number      String?
  neighborhood String?
  city        String
  state       String
  zipCode     String?
  contact     Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Worksite {
  id        String  @id @default(cuid())
  contactId String
  name      String
  address   String?
  type      String?
  stage     String?
  recurringMaterials String[] @default([])
  estimatedDurationDays Int?
  notes     String?
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  quotes    Quote[]
}

model Conversation {
  id            String         @id @default(cuid())
  storeId       String
  contactId     String
  assignedToId  String?
  status        TicketStatus   @default(ABERTO)
  slaDueAt      DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  store         Store          @relation(fields: [storeId], references: [id])
  contact       Contact        @relation(fields: [contactId], references: [id])
  messages      Message[]
  ticket        Ticket?
  opportunities Opportunity[]
  receivables   Receivable[]

  @@index([storeId, status, assignedToId])
}

model Message {
  id              String           @id @default(cuid())
  conversationId  String
  providerMessageId String?
  direction       MessageDirection
  type            MessageType
  body            String?
  mediaUrl        String?
  metadata        Json?
  createdAt       DateTime         @default(now())
  conversation    Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Ticket {
  id             String       @id @default(cuid())
  storeId        String
  conversationId String       @unique
  assignedToId   String?
  status         TicketStatus @default(ABERTO)
  tags           String[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  store          Store        @relation(fields: [storeId], references: [id])
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  assignedTo     User?        @relation("TicketAssignee", fields: [assignedToId], references: [id])
}

model PipelineStage {
  id             String        @id @default(cuid())
  name           String
  orderIndex     Int
  isClosedWon    Boolean       @default(false)
  isClosedLost   Boolean       @default(false)
  opportunities  Opportunity[]
}

model Opportunity {
  id              String         @id @default(cuid())
  storeId         String
  conversationId  String
  stageId         String
  name            String
  estimatedValue  Decimal        @db.Decimal(12, 2)
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  store           Store          @relation(fields: [storeId], references: [id])
  conversation    Conversation   @relation(fields: [conversationId], references: [id])
  stage           PipelineStage  @relation(fields: [stageId], references: [id])
  stageHistory    StageHistory[]
  quotes          Quote[]
}

model StageHistory {
  id             String      @id @default(cuid())
  opportunityId  String
  fromStageId    String?
  toStageId      String
  changedById    String?
  changedAt      DateTime    @default(now())
  opportunity    Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
}

model Product {
  id          String               @id @default(cuid())
  storeId     String
  sku         String
  name        String
  unit        ProductUnit
  isActive    Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  store       Store                @relation(fields: [storeId], references: [id])
  prices      ProductPrice[]
  stocks      ProductStockByStore[]
  priceRules  PriceRule[]
  quoteItems  QuoteItem[]
  inventoryMovements InventoryMovement[]

  @@unique([storeId, sku])
}

model ProductPrice {
  id         String   @id @default(cuid())
  productId  String
  storeId    String
  price      Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, storeId])
}

model ProductStockByStore {
  id         String   @id @default(cuid())
  productId  String
  storeId    String
  quantity   Decimal  @db.Decimal(12, 3)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, storeId])
}

model ProductImportJob {
  id          String               @id @default(cuid())
  type        ProductImportJobType
  fileName    String
  status      ProductImportJobStatus @default(PENDING)
  optionsJson Json
  totalsJson  Json?
  createdById String?
  createdAt   DateTime             @default(now())
  finishedAt  DateTime?
  createdBy   User?                @relation(fields: [createdById], references: [id])
  errors      ProductImportError[]
  movements   InventoryMovement[]
}

model ProductImportError {
  id           String           @id @default(cuid())
  jobId        String
  rowNumber    Int
  productCode  String?
  errorMessage String
  rawRowJson   Json?
  job          ProductImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, rowNumber])
}

model InventoryMovement {
  id              String                @id @default(cuid())
  productId       String
  movementType    InventoryMovementType
  quantity        Decimal               @db.Decimal(12, 3)
  previousBalance Decimal               @db.Decimal(12, 3)
  newBalance      Decimal               @db.Decimal(12, 3)
  referenceJobId  String?
  createdById     String?
  createdAt       DateTime              @default(now())
  product         Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  referenceJob    ProductImportJob?     @relation(fields: [referenceJobId], references: [id], onDelete: SetNull)
}

model Quote {
  id                String      @id @default(cuid())
  storeId           String
  contactId         String
  opportunityId     String?
  worksiteId        String?
  createdById       String
  subtotal          Decimal     @db.Decimal(12, 2)
  discountPercent   Decimal     @db.Decimal(5, 2)
  total             Decimal     @db.Decimal(12, 2)
  status            String      @default("ENVIADO")
  pdfUrl            String?
  approvedAtWhatsApp Boolean    @default(false)
  riskLevel         RiskLevel    @default(BAIXO)
  riskReasons       String[]
  needsSupervisorApproval Boolean @default(false)
  createdAt         DateTime    @default(now())
  items             QuoteItem[]
  opportunity       Opportunity? @relation(fields: [opportunityId], references: [id])
  worksite          Worksite?    @relation(fields: [worksiteId], references: [id])
  receivable        Receivable?
  followupTasks     QuoteFollowupTask[]

  @@index([storeId, createdAt])
}

model QuoteItem {
  id            String   @id @default(cuid())
  quoteId       String
  productId     String
  productName   String
  unit          String
  quantity      Decimal  @db.Decimal(12, 3)
  unitPrice     Decimal  @db.Decimal(12, 2)
  discountPct   Decimal  @db.Decimal(5, 2)
  subtotal      Decimal  @db.Decimal(12, 2)
  quote         Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [productId], references: [id])
}

model AiSuggestion {
  id                  String   @id @default(cuid())
  conversationId      String
  inputContextIds     String[]
  responseDraft       String
  confidence          Decimal  @db.Decimal(3, 2)
  sources             String[]
  requiresHuman       Boolean
  approvedById        String?
  finalSentMessageId  String?
  createdAt           DateTime @default(now())
  approvedBy          User?    @relation("AiApprovedBy", fields: [approvedById], references: [id])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  entity      String
  entityId    String?
  beforeData  Json?
  afterData   Json?
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id])
}

model CustomerScore {
  id                  String       @id @default(cuid())
  contactId           String       @unique
  frequencyScore      Int
  avgTicketScore      Int
  responseTimeScore   Int
  complaintsScore     Int
  activeWorksitesScore Int
  totalScore          Int
  tier                CustomerTier
  updatedAt           DateTime     @updatedAt
  contact             Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model SalesCopilotSuggestion {
  id                  String   @id @default(cuid())
  conversationId      String
  suggestion          String
  confidence          Decimal  @db.Decimal(3, 2)
  requiresHuman       Boolean
  reasoning           String
  closureProbability  Decimal  @db.Decimal(5, 2)
  estimatedTicket     Decimal  @db.Decimal(12, 2)
  repurchaseChance    Decimal  @db.Decimal(5, 2)
  createdAt           DateTime @default(now())
}

model RiskEvent {
  id                  String    @id @default(cuid())
  quoteId             String?
  conversationId      String?
  level               RiskLevel
  reason              String
  blocked             Boolean   @default(true)
  createdAt           DateTime  @default(now())
}

model QuoteFollowupTask {
  id                  String            @id @default(cuid())
  quoteId             String
  status              FollowupTaskStatus @default(PENDING)
  suggestedMessage    String?
  dueAt               DateTime
  createdAt           DateTime          @default(now())
  quote               Quote             @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model SellerGoal {
  id                 String   @id @default(cuid())
  storeId            String
  userId             String
  monthRef           String
  quotesTarget       Int
  conversionTarget   Decimal  @db.Decimal(5, 2)
  avgTicketTarget    Decimal  @db.Decimal(12, 2)
  revenueTarget      Decimal  @db.Decimal(12, 2)
  store              Store    @relation(fields: [storeId], references: [id])

  @@index([storeId, monthRef])
}

model PriceRule {
  id            String      @id @default(cuid())
  storeId       String
  productId     String?
  role          RoleName
  maxDiscount   Decimal     @db.Decimal(5, 2)
  minUnitPrice  Decimal?    @db.Decimal(12, 2)
  createdAt     DateTime    @default(now())
  store         Store       @relation(fields: [storeId], references: [id])
  product       Product?    @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Receivable {
  id                   String                  @id @default(cuid())
  conversationId       String
  contactId            String
  quoteId              String                  @unique
  total                Decimal                 @db.Decimal(12, 2)
  dueDate              DateTime
  status               ReceivableStatus        @default(PENDENTE)
  paymentMethod        String
  createdBy            String
  chargeLink           String?
  boletoExternalRef    String?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  conversation         Conversation            @relation(fields: [conversationId], references: [id])
  quote                Quote                   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  installments         ReceivableInstallment[]
  payments             Payment[]
  reminderLogs         ChargeReminderLog[]
}

model ReceivableInstallment {
  id            String          @id @default(cuid())
  receivableId  String
  number        Int
  amount        Decimal         @db.Decimal(12, 2)
  dueDate       DateTime
  status        ReceivableStatus @default(PENDENTE)
  receivable    Receivable      @relation(fields: [receivableId], references: [id], onDelete: Cascade)

  @@index([receivableId, dueDate])
}

model Payment {
  id            String     @id @default(cuid())
  receivableId  String
  amount        Decimal    @db.Decimal(12, 2)
  paidAt        DateTime
  method        String
  reference     String?
  receivable    Receivable @relation(fields: [receivableId], references: [id], onDelete: Cascade)
}

model FiscalDoc {
  id            String    @id @default(cuid())
  receivableId  String?
  quoteId       String?
  externalRef   String?
  createdAt     DateTime  @default(now())
}

model ChargeReminderLog {
  id            String    @id @default(cuid())
  receivableId  String
  reminderType  String
  sentAt        DateTime  @default(now())
  receivable    Receivable @relation(fields: [receivableId], references: [id], onDelete: Cascade)

  @@unique([receivableId, reminderType])
}

model WhatsAppSetting {
  id                 String       @id @default(cuid())
  accountName        String
  providerType       ProviderType
  phoneNumberE164    String
  countryCode        String?
  configJson         String
  webhookVerifyToken String?
  isActive           Boolean      @default(false)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model AiSetting {
  id                    String    @id @default(cuid())
  businessRulesPrompt   String
  modeDefault           AiMode    @default(ASSISTIDO)
  confidenceThreshold   Decimal   @db.Decimal(3, 2) @default(0.8)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model WhatsAppMessageLog {
  id                 String           @id @default(cuid())
  providerType       ProviderType
  fromNumber         String?
  toNumber           String
  payloadPreview     String
  status             MessageLogStatus
  externalMessageId  String?
  errorMessage       String?
  createdAt          DateTime         @default(now())
}

model WebhookEvent {
  id           String       @id @default(cuid())
  providerType ProviderType
  eventType    String
  rawPayload   Json
  receivedAt   DateTime     @default(now())
}
