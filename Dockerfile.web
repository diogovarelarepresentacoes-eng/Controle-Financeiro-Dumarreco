FROM node:20-alpine AS build

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY index.html ./
COPY tsconfig.json ./
COPY vite.config.js ./
COPY src ./src

ARG VITE_API_BASE_URL
ARG VITE_USE_BACKEND
ARG VITE_CRM_API_URL
ARG VITE_ADMIN_LOGIN
ARG VITE_ADMIN_PASS
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_USE_BACKEND=$VITE_USE_BACKEND
ENV VITE_CRM_API_URL=$VITE_CRM_API_URL
ENV VITE_ADMIN_LOGIN=$VITE_ADMIN_LOGIN
ENV VITE_ADMIN_PASS=$VITE_ADMIN_PASS

RUN npm run build

FROM nginx:1.27-alpine
RUN mkdir -p /var/www/certbot
COPY docker/nginx-http.conf /docker/nginx-http.conf
COPY docker/nginx-ssl.conf /docker/nginx-ssl.conf
COPY docker/docker-entrypoint-web.sh /docker-entrypoint-web.sh
RUN chmod +x /docker-entrypoint-web.sh
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80 443
ENTRYPOINT ["/docker-entrypoint-web.sh"]
