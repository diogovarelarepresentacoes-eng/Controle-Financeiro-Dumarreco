POSTGRES_DB=controle_financeiro
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque-esta-senha-segura
POSTGRES_PORT=5432
API_PORT=3333
WEB_PORT=80

# Credenciais do admin (seed inicial)
ADMIN_LOGIN=DumarrecoAdmin
ADMIN_PASS=troque-esta-senha-segura

# Frontend (build-time) - usado pelo servico `web` no Docker Compose
#
# ATENCAO PARA VPS/PRODUCAO:
#   Defina VITE_API_BASE_URL como a URL publica do seu servidor.
#   Exemplos:
#     VITE_API_BASE_URL=http://123.45.67.89        (IP do VPS)
#     VITE_API_BASE_URL=https://financeiro.meusite.com  (dominio com HTTPS)
#
#   O nginx ja faz proxy de /api/* para a API interna automaticamente.
#   Nao use http://localhost:3333 em producao - o browser do usuario
#   tentaria acessar a porta 3333 na maquina DELE, nao no servidor.
#
# Para desenvolvimento local (docker-compose up na sua maquina), o valor
# abaixo funciona normalmente pois browser e servidor sao o mesmo host.
VITE_API_BASE_URL=http://localhost:3333
VITE_CRM_API_URL=http://localhost:4000
