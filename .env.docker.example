# =============================================================
# Variaveis para deploy Docker (Hostinger VPS)
# Copie para .env.docker e ajuste antes de usar em producao.
# NUNCA commite o .env.docker real — ele esta no .gitignore.
# =============================================================

# -- Banco de dados PostgreSQL --------------------------------
POSTGRES_DB=controle_financeiro
POSTGRES_USER=postgres
POSTGRES_PASSWORD=TROQUE_ESTA_SENHA
POSTGRES_PORT=5432

# -- Portas dos servicos --------------------------------------
API_PORT=3333
WEB_PORT=80

# -- Credenciais do administrador -----------------------------
# Troque antes de usar em producao — os defaults no codigo sao publicos
ADMIN_LOGIN=TROQUE_O_LOGIN_ADMIN
ADMIN_PASS=TROQUE_A_SENHA_ADMIN

# -- Frontend (variaveis de build-time do Vite) ---------------
# VITE_API_BASE_URL deve ficar VAZIO no Docker com nginx proxy reverso.
# Vazio = o frontend usa URLs relativas (/api/...) que o nginx redireciona
# internamente para o container api:3333. Porta 3333 nao precisa estar
# aberta no firewall.
# SO defina um valor (ex: http://IP:3333) se expor a API diretamente
# sem nginx — o que exige a porta 3333 aberta e configura CORS separado.
VITE_API_BASE_URL=
VITE_USE_BACKEND=true

# -- CRM (modulo opcional — deixe vazio se nao usar CRM) ------
VITE_CRM_API_URL=
