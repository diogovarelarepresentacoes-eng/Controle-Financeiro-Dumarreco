generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Supplier {
  id          String     @id @default(uuid())
  cnpj        String?    @unique
  legalName   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  purchases   Purchase[]
}

model Purchase {
  id                    String             @id @default(uuid())
  supplierId            String
  supplier              Supplier           @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  issueDate             DateTime
  competenceMonth       String
  description           String?
  notes                 String?
  totalAmount           Decimal            @db.Decimal(14, 2)
  category              String?
  costCenter            String?
  hasInvoice            Boolean            @default(false)
  source                String
  nfeAccessKey          String?            @unique
  nfeNumber             String?
  nfeSeries             String?
  nfeNatureOperation    String?
  recipientName         String?
  recipientCnpj         String?
  totalProducts         Decimal?           @db.Decimal(14, 2)
  totalInvoice          Decimal?           @db.Decimal(14, 2)
  totalTaxes            Decimal?           @db.Decimal(14, 2)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  deletedAt             DateTime?
  items                 PurchaseItem[]
  documents             PurchaseDocument[]
  payables              Payable[]
}

model PurchaseItem {
  id          String   @id @default(uuid())
  purchaseId  String
  purchase    Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  description String
  ncm         String?
  quantity    Decimal  @db.Decimal(14, 4)
  unitAmount  Decimal  @db.Decimal(14, 4)
  totalAmount Decimal  @db.Decimal(14, 2)
}

model PurchaseDocument {
  id            String   @id @default(uuid())
  purchaseId    String
  purchase      Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  documentType  String
  fileName      String
  fileContent   String
  nfeAccessKey  String?
  createdAt     DateTime @default(now())
}

model Payable {
  id            String   @id @default(uuid())
  purchaseId    String?
  purchase      Purchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  description   String
  dueDate       DateTime
  amount        Decimal  @db.Decimal(14, 2)
  status        String   @default("pending")
  paymentDate   DateTime?
  paymentMethod String?
  supplierName  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model XmlImportLog {
  id           String   @id @default(uuid())
  performedBy  String
  occurredAt   DateTime @default(now())
  success      Boolean
  message      String
  nfeAccessKey String?
  purchaseId   String?
}

enum ProductImportJobType {
  PRODUCT_IMPORT
  STOCK_UPDATE
}

enum ProductImportJobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum InventoryMovementType {
  IMPORT_SET
  IMPORT_ADD
  MANUAL_ADJUST
}

model Product {
  id               String              @id @default(uuid())
  code             String              @unique
  description      String
  priceInstallment Decimal             @db.Decimal(12, 2)
  stockBalance     Decimal             @db.Decimal(12, 3)
  unit             String?
  isActive         Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  movements        InventoryMovement[]

  @@index([code])
}

model ProductImportJob {
  id         String               @id @default(uuid())
  type       ProductImportJobType
  fileName   String
  status     ProductImportJobStatus @default(PENDING)
  optionsJson Json
  totalsJson  Json?
  createdBy   String?
  createdAt   DateTime            @default(now())
  finishedAt  DateTime?
  errors      ProductImportError[]
  movements   InventoryMovement[]
}

model ProductImportError {
  id           String           @id @default(uuid())
  jobId        String
  rowNumber    Int
  productCode  String?
  errorMessage String
  rawRowJson   Json?
  job          ProductImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, rowNumber])
}

model InventoryMovement {
  id              String               @id @default(uuid())
  productId       String
  movementType    InventoryMovementType
  quantity        Decimal              @db.Decimal(12, 3)
  previousBalance Decimal              @db.Decimal(12, 3)
  newBalance      Decimal              @db.Decimal(12, 3)
  referenceJobId  String?
  createdBy       String?
  createdAt       DateTime             @default(now())
  product         Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  referenceJob    ProductImportJob?    @relation(fields: [referenceJobId], references: [id], onDelete: SetNull)
}

model MaquinaCartao {
  id          String              @id @default(uuid())
  nome        String
  adquirente  String
  descricao   String?
  ativo       Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  taxas       TaxaMaquinaCartao[]

  @@index([ativo])
}

model TaxaMaquinaCartao {
  id               String        @id @default(uuid())
  maquinaCartaoId  String
  maquinaCartao    MaquinaCartao @relation(fields: [maquinaCartaoId], references: [id], onDelete: Cascade)
  tipoCartao       String
  parcelas         Int
  taxaPercentual   Decimal       @db.Decimal(5, 2)
  ativo            Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([maquinaCartaoId, tipoCartao, parcelas])
  @@index([maquinaCartaoId, tipoCartao, parcelas])
}
