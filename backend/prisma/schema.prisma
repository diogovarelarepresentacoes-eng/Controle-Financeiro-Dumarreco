generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Supplier {
  id          String     @id @default(uuid())
  cnpj        String?    @unique
  legalName   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  purchases   Purchase[]
}

model Purchase {
  id                    String             @id @default(uuid())
  supplierId            String
  supplier              Supplier           @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  issueDate             DateTime
  competenceMonth       String
  description           String?
  notes                 String?
  totalAmount           Decimal            @db.Decimal(14, 2)
  category              String?
  costCenter            String?
  hasInvoice            Boolean            @default(false)
  source                String
  nfeAccessKey          String?            @unique
  nfeNumber             String?
  nfeSeries             String?
  nfeNatureOperation    String?
  recipientName         String?
  recipientCnpj         String?
  totalProducts         Decimal?           @db.Decimal(14, 2)
  totalInvoice          Decimal?           @db.Decimal(14, 2)
  totalTaxes            Decimal?           @db.Decimal(14, 2)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  deletedAt             DateTime?
  items                 PurchaseItem[]
  documents             PurchaseDocument[]
  payables              Payable[]
}

model PurchaseItem {
  id          String   @id @default(uuid())
  purchaseId  String
  purchase    Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  description String
  ncm         String?
  quantity    Decimal  @db.Decimal(14, 4)
  unitAmount  Decimal  @db.Decimal(14, 4)
  totalAmount Decimal  @db.Decimal(14, 2)
}

model PurchaseDocument {
  id            String   @id @default(uuid())
  purchaseId    String
  purchase      Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  documentType  String
  fileName      String
  fileContent   String
  nfeAccessKey  String?
  createdAt     DateTime @default(now())
}

model Payable {
  id            String   @id @default(uuid())
  purchaseId    String?
  purchase      Purchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  description   String
  dueDate       DateTime
  amount        Decimal  @db.Decimal(14, 2)
  status        String   @default("pending")
  paymentDate   DateTime?
  paymentMethod String?
  supplierName  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model XmlImportLog {
  id           String   @id @default(uuid())
  performedBy  String
  occurredAt   DateTime @default(now())
  success      Boolean
  message      String
  nfeAccessKey String?
  purchaseId   String?
}

enum ProductImportJobType {
  PRODUCT_IMPORT
  STOCK_UPDATE
}

enum ProductImportJobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum InventoryMovementType {
  IMPORT_SET
  IMPORT_ADD
  MANUAL_ADJUST
}

model Product {
  id               String              @id @default(uuid())
  code             String              @unique
  description      String
  priceInstallment Decimal             @db.Decimal(12, 2)
  stockBalance     Decimal             @db.Decimal(12, 3)
  unit             String?
  isActive         Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  movements        InventoryMovement[]

  @@index([code])
}

model ProductImportJob {
  id         String               @id @default(uuid())
  type       ProductImportJobType
  fileName   String
  status     ProductImportJobStatus @default(PENDING)
  optionsJson Json
  totalsJson  Json?
  createdBy   String?
  createdAt   DateTime            @default(now())
  finishedAt  DateTime?
  errors      ProductImportError[]
  movements   InventoryMovement[]
}

model ProductImportError {
  id           String           @id @default(uuid())
  jobId        String
  rowNumber    Int
  productCode  String?
  errorMessage String
  rawRowJson   Json?
  job          ProductImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, rowNumber])
}

model InventoryMovement {
  id              String               @id @default(uuid())
  productId       String
  movementType    InventoryMovementType
  quantity        Decimal              @db.Decimal(12, 3)
  previousBalance Decimal              @db.Decimal(12, 3)
  newBalance      Decimal              @db.Decimal(12, 3)
  referenceJobId  String?
  createdBy       String?
  createdAt       DateTime             @default(now())
  product         Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  referenceJob    ProductImportJob?    @relation(fields: [referenceJobId], references: [id], onDelete: SetNull)
}

model MaquinaCartao {
  id          String              @id @default(uuid())
  nome        String
  adquirente  String
  descricao   String?
  ativo       Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  taxas       TaxaMaquinaCartao[]

  @@index([ativo])
}

model TaxaMaquinaCartao {
  id               String        @id @default(uuid())
  maquinaCartaoId  String
  maquinaCartao    MaquinaCartao @relation(fields: [maquinaCartaoId], references: [id], onDelete: Cascade)
  tipoCartao       String
  parcelas         Int
  taxaPercentual   Decimal       @db.Decimal(5, 2)
  ativo            Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([maquinaCartaoId, tipoCartao, parcelas])
  @@index([maquinaCartaoId, tipoCartao, parcelas])
}

model TaxaCartao {
  id                 String   @id @default(uuid())
  descricao          String
  tipoCartao         String
  quantidadeParcelas Int
  taxaPercentual     Decimal  @db.Decimal(5, 2)
  ativo              Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([tipoCartao, quantidadeParcelas])
}

// ── Finance models ──────────────────────────────────────────

model ContaBanco {
  id            String                @id @default(uuid())
  nome          String
  banco         String
  agencia       String
  conta         String
  saldoInicial  Decimal               @db.Decimal(14, 2)
  saldoAtual    Decimal               @db.Decimal(14, 2)
  formasAceitas Json                  @default("[]")
  ativo         Boolean               @default(true)
  criadoEm      DateTime              @default(now())
  movimentacoes MovimentacaoBancaria[]
  boletos       Boleto[]
  vendas        Venda[]
  despesas      Despesa[]
}

model Boleto {
  id               String       @id @default(uuid())
  descricao        String
  valor            Decimal      @db.Decimal(14, 2)
  vencimento       String
  pago             Boolean      @default(false)
  dataPagamento    String?
  origemPagamento  String?
  contaBancoId     String?
  contaBanco       ContaBanco?  @relation(fields: [contaBancoId], references: [id], onDelete: SetNull)
  compraId         String?
  criadoEm         DateTime     @default(now())
  movimentacoes    MovimentacaoBancaria[]
}

model MovimentacaoBancaria {
  id            String      @id @default(uuid())
  contaBancoId  String
  contaBanco    ContaBanco  @relation(fields: [contaBancoId], references: [id], onDelete: Cascade)
  tipo          String
  valor         Decimal     @db.Decimal(14, 2)
  descricao     String
  boletoId      String?
  boleto        Boleto?     @relation(fields: [boletoId], references: [id], onDelete: SetNull)
  vendaId       String?
  venda         Venda?      @relation(fields: [vendaId], references: [id], onDelete: SetNull)
  despesaId     String?
  despesa       Despesa?    @relation(fields: [despesaId], references: [id], onDelete: SetNull)
  data          String
}

model Venda {
  id                     String      @id @default(uuid())
  descricao              String
  valor                  Decimal     @db.Decimal(14, 2)
  formaPagamento         String
  contaBancoId           String?
  contaBanco             ContaBanco? @relation(fields: [contaBancoId], references: [id], onDelete: SetNull)
  data                   String
  criadoEm               DateTime    @default(now())
  maquinaCartaoId        String?
  maquinaCartaoNome      String?
  tipoPagamentoCartao    String?
  quantidadeParcelas     Int?
  valorBruto             Decimal?    @db.Decimal(14, 2)
  taxaPercentualCartao   Decimal?    @db.Decimal(5, 2)
  valorTaxaCartao        Decimal?    @db.Decimal(14, 2)
  valorLiquido           Decimal?    @db.Decimal(14, 2)
  observacaoFinanceira   String?
  movimentacoes          MovimentacaoBancaria[]
}

model FaturamentoMensal {
  id                          String   @id @default(uuid())
  ano                         Int
  mes                         Int
  valorInventarioInicio       Decimal  @db.Decimal(14, 2) @default(0)
  usarInventarioInicioManual  Boolean  @default(false)
  valorInventarioFim          Decimal  @db.Decimal(14, 2) @default(0)
  usarInventarioFimManual     Boolean  @default(false)
  comprasDoMes                Decimal  @db.Decimal(14, 2) @default(0)
  compraSemNota               Decimal  @db.Decimal(14, 2) @default(0)
  acordos                     Decimal  @db.Decimal(14, 2) @default(0)
  mercadorias                 Decimal  @db.Decimal(14, 2) @default(0)
  criadoEm                    DateTime @default(now())
  atualizadoEm                DateTime @updatedAt

  @@unique([ano, mes])
}

model Despesa {
  id                   String                @id @default(uuid())
  descricao            String
  categoria            String
  tipo                 String
  valor                Decimal               @db.Decimal(14, 2)
  dataVencimento       String
  dataPagamento        String?
  status               String                @default("pendente")
  formaPagamento       String
  origemPagamento      String?
  contaBancoId         String?
  contaBanco           ContaBanco?           @relation(fields: [contaBancoId], references: [id], onDelete: SetNull)
  fornecedor           String                @default("")
  centroCusto          String                @default("")
  observacoes          String                @default("")
  recorrente           Boolean               @default(false)
  periodicidade        String?
  recorrenciaOrigemId  String?
  criadoEm             DateTime              @default(now())
  atualizadoEm         DateTime              @updatedAt
  movimentacoes        MovimentacaoBancaria[]
}

model DeletedRecurrenceMarker {
  id              String   @id @default(uuid())
  origemId        String
  dataVencimento  String
  deletedAt       DateTime @default(now())

  @@unique([origemId, dataVencimento])
}

model Usuario {
  id        String   @id @default(uuid())
  login     String   @unique
  senhaHash String
  root      Boolean  @default(false)
  criadoEm  DateTime @default(now())
}
