# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_BANCO?schema=public
# Opcao 1 - senha padrao (Docker ou instalacao tipica):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/controle_financeiro?schema=public"
# Opcao 2 - sem senha (algumas instalacoes Windows):
# DATABASE_URL="postgresql://postgres:@localhost:5432/controle_financeiro?schema=public"
# Opcao 3 - Docker: use host.docker.internal no lugar de localhost se a API rodar no container
PORT=3333
